<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="hr.tvz.cyberpunkunfolds.ui.controller.LobbyController">
  <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

  <top>
    <HBox spacing="10">
      <Button text="Back" onAction="#onBack"/>
      <Label text="Lobby (RMI + JNDI)" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
    </HBox>
  </top>

  <center>
    <SplitPane>
      <VBox spacing="8" prefWidth="280">
        <padding><Insets right="10"/></padding>
        <Label text="Rooms" style="-fx-font-weight: bold;" />
        <ListView fx:id="roomsList" VBox.vgrow="ALWAYS"/>
        <HBox spacing="8">
          <Button text="Refresh" onAction="#onRefresh"/>
          <Button text="Create Room" onAction="#onCreateRoom"/>
        </HBox>
        <Button text="Join Selected" onAction="#onJoinRoom"/>
        <Button text="Start Game" onAction="#onStartGame" styleClass="btn-start"/>
      </VBox>

      <VBox spacing="8">
        <padding><Insets left="10"/></padding>
        <Label text="Chat" style="-fx-font-weight: bold;" />
        <TextArea fx:id="chatArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS" prefRowCount="12"/>
        <HBox spacing="8">
          <TextField fx:id="chatInput" promptText="Message..." onAction="#onSendChat" HBox.hgrow="ALWAYS"/>
          <Button text="Send" onAction="#onSendChat" prefWidth="90"/>
        </HBox>
      </VBox>
    </SplitPane>
  </center>
</BorderPane>
