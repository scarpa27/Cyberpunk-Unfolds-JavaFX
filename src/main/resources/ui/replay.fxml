<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="hr.tvz.cyberpunkunfolds.ui.controller.ReplayController">
  <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

  <top>
    <HBox spacing="10">
      <Button text="Back" onAction="#onBack"/>
      <Label text="Replay (XML)" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
    </HBox>
  </top>

  <center>
    <VBox spacing="10">
      <HBox spacing="10">
        <Button text="Load moves.xml" onAction="#onLoadXml"/>
        <Button text="Play" onAction="#onPlay"/>
        <Button text="Pause" onAction="#onPause"/>
      </HBox>
      <Slider fx:id="progressSlider" min="0" max="1" value="0"/>
      <TextArea fx:id="replayArea" editable="false" wrapText="true"/>
    </VBox>
  </center>
</BorderPane>
